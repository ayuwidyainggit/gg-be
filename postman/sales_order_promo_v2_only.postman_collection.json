                {
                    "name": "Detail Sales Order v2 (GET /sales/v2/orders/{ro_no}) + Assertions",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test('Status code is 200', function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "const resp = pm.response.json();",
                                    "const data = resp?.data || {};",
                                    "const scenario = pm.collectionVariables.get('scenario_so');",
                                    "const expectedMap = JSON.parse(pm.collectionVariables.get('expected_summary_json') || '{}');",
                                    "const expected = expectedMap[scenario];",
                                    "",
                                    "pm.test('Scenario configuration exists', function () {",
                                    "    pm.expect(expected, 'set scenario_so first').to.be.an('object');",
                                    "});",
                                    "",
                                    "function normalizeText(v) {",
                                    "    return String(v || '').toUpperCase().replace(/[^A-Z0-9]/g, '');",
                                    "}",
                                    "",
                                    "function addArray(target, arr) {",
                                    "    if (!Array.isArray(arr)) return;",
                                    "    arr.forEach(function (x) {",
                                    "        if (x !== null && x !== undefined && String(x).trim() !== '') target.push(String(x));",
                                    "    });",
                                    "}",
                                    "",
                                    "function collectRemarks(source) {",
                                    "    const out = [];",
                                    "    if (!source || typeof source !== 'object') return out;",
                                    "",
                                    "    addArray(out, source?.details?.promo_remarks_so);",
                                    "    addArray(out, source?.details?.promo_remarks_final);",
                                    "    addArray(out, source?.details?.promo_remarks_po);",
                                    "    addArray(out, source?.details_final?.promo_remarks_so);",
                                    "    addArray(out, source?.details_final?.promo_remarks_final);",
                                    "    addArray(out, source?.details_final?.promo_remarks_po);",
                                    "    addArray(out, source?.purchase_details?.promo_remarks_so);",
                                    "    addArray(out, source?.purchase_details?.promo_remarks_final);",
                                    "    addArray(out, source?.purchase_details?.promo_remarks_po);",
                                    "",
                                    "    const groups = [source?.details, source?.details_final, source?.purchase_details];",
                                    "    groups.forEach(function (g) {",
                                    "        ['normal', 'promo'].forEach(function (k) {",
                                    "            (g?.[k] || []).forEach(function (it) {",
                                    "                addArray(out, it?.remarks);",
                                    "                addArray(out, it?.promo_remarks_so);",
                                    "                addArray(out, it?.promo_remarks_final);",
                                    "                addArray(out, it?.promo_remarks_po);",
                                    "            });",
                                    "        });",
                                    "    });",
                                    "",
                                    "    (source?.remarks || []).forEach(function (r) {",
                                    "        if (r?.description) out.push(String(r.description));",
                                    "    });",
                                    "",
                                    "    return out;",
                                    "}",
                                    "",
                                    "function pickNumber(values) {",
                                    "    for (let i = 0; i < values.length; i += 1) {",
                                    "        const n = Number(values[i]);",
                                    "        if (Number.isFinite(n)) return n;",
                                    "    }",
                                    "    return null;",
                                    "}",
                                    "",
                                    "const allRemarks = collectRemarks(data);",
                                    "const normalizedRemarks = allRemarks.map(normalizeText).filter(Boolean);",
                                    "",
                                    "(expected?.remarks || []).forEach(function (remark) {",
                                    "    const expectedNorm = normalizeText(remark);",
                                    "    pm.test('Promo remark contains ' + remark, function () {",
                                    "        const found = normalizedRemarks.some(function (r) { return r.includes(expectedNorm); });",
                                    "        pm.expect(found, 'actual remarks: ' + JSON.stringify(allRemarks)).to.equal(true);",
                                    "    });",
                                    "});",
                                    "",
                                    "const promoBarangActual = pickNumber([",
                                    "    data?.promo_bg_value,",
                                    "    data?.promo_bg_value_final,",
                                    "    data?.promotion_product",
                                    "]);",
                                    "",
                                    "pm.test('Promo barang matches expected', function () {",
                                    "    pm.expect(promoBarangActual, 'promo barang not found in response').to.not.equal(null);",
                                    "    pm.expect(promoBarangActual).to.be.closeTo(Number(expected?.promo_barang || 0), 0.5);",
                                    "});",
                                    "",
                                    "const promoUangActual = pickNumber([",
                                    "    data?.promo_value,",
                                    "    data?.promo_value_final,",
                                    "    data?.promotion_money",
                                    "]);",
                                    "",
                                    "pm.test('Promo uang matches expected', function () {",
                                    "    pm.expect(promoUangActual, 'promo uang not found in response').to.not.equal(null);",
                                    "    pm.expect(promoUangActual).to.be.closeTo(Number(expected?.promo_uang || 0), 0.5);",
                                    "});",
                                    "",
                                    "if (expected && expected.regular_discount !== null && expected.regular_discount !== undefined) {",
                                    "    const regularDiscountActual = pickNumber([",
                                    "        data?.disc_value,",
                                    "        data?.disc_value_final,",
                                    "        data?.discount",
                                    "    ]);",
                                    "",
                                    "    pm.test('Regular discount matches expected', function () {",
                                    "        pm.expect(regularDiscountActual, 'regular discount not found in response').to.not.equal(null);",
                                    "        pm.expect(regularDiscountActual).to.be.closeTo(Number(expected.regular_discount), 0.5);",
                                    "    });",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
