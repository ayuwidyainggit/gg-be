                            ],
                            "path": [
                                "v1",
                                "sales-target-distributor"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Update Sales Target Distributor",
                    "request": {
                        "method": "PATCH",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{access_token}}",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"yearly_target\": 150000000,\n    \"data\": [\n        {\n            \"month\": 1,\n            \"monthly_target\": 12500000\n        }\n    ]\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
