{
    "info": {
        "_postman_id": "sales-target-collection-uuid",
        "name": "Sales Target & Distributor Collection",
        "description": "Collection for testing Sales Target and Sales Target Distributor endpoints",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Auth",
            "item": [
                {
                    "name": "Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "if (jsonData.data && jsonData.data.token && jsonData.data.token.access) {",
                                    "    pm.environment.set(\"access_token\", jsonData.data.token.access);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"{{email}}\",\n    \"password\": \"{{password}}\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{system_url}}/v1/users/login",
                            "host": [
                                "{{system_url}}"
                            ],
                            "path": [
                                "v1",
                                "users",
                                "login"
                            ]
                        }
                    },
                    "response": []
                }
            ]
        },
        {
