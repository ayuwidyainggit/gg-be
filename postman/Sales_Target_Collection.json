                                "key": "Authorization",
                                "value": "Bearer {{access_token}}",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"year\": 2025,\n    \"area_id\": 1,\n    \"region_id\": 1,\n    \"distributor_id\": 1,\n    \"yearly_target\": 120000000,\n    \"status\": 1,\n    \"data\": [\n        {\n            \"month\": 1,\n            \"monthly_target\": 10000000\n        },\n        {\n            \"month\": 2,\n            \"monthly_target\": 10000000\n        },\n        {\n            \"month\": 3,\n            \"monthly_target\": 10000000\n        }\n    ]\n}",
