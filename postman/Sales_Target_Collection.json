                                "{{master_url}}"
                            ],
                            "path": [
                                "v1",
                                "sales-target-distributor",
                                ":id"
                            ],
                            "variable": [
                                {
                                    "key": "id",
                                    "value": "1"
                                }
                            ]
                        }
                    },
                    "response": []
                }
            ]
        },
