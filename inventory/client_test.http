####### End Of Stock #######

####### Stock Opname #######

# @name get_stock_opname_lookup
GET {{host-inventory}}/v1/stocks/opname-lookup
    ?wh_id=1
    &product_hierarchy=1
    &include_zero_stock=true
    &is_show_price=false
Accept: application/json
Accept-Language: en
Authorization: Bearer {{login.response.body.data.token.access}}
###

# @name get_stock_opname_statuses
GET {{host-inventory}}/v1/stock-opname/statuses
Accept: application/json
Accept-Language: en
Authorization: Bearer {{login.response.body.data.token.access}}
###

# @name get_stock_opname_product_hierarchy
GET {{host-inventory}}/v1/stock-opname/product-hierarchy
Accept: application/json
Accept-Language: en
Authorization: Bearer {{login.response.body.data.token.access}}
###

# @name get_stock_opname_list
GET {{host-inventory}}/v1/stock-opname
    ?page=1
    &limit=10
    &q=
    &from=1704067200
    &to=1735689599
Accept: application/json
Accept-Language: en
Authorization: Bearer {{login.response.body.data.token.access}}
###

# @name create_stock_opname
POST {{host-inventory}}/v1/stock-opname
Content-Type: application/json
Accept-Language: en
Authorization: Bearer {{login.response.body.data.token.access}}

{
    "wh_id": 63,
    "notes": "",
    "scheduled_at": "2024-11-30 11:36:00",
    "assign_to_emp_id": 203,
    "product_hierarchy": 1,
    "include_zero_stock": false,
    "is_show_current_stock": true
}
###

@doc_no = SE2411300008
# @name get_stock_opname_reports
GET {{host-inventory}}/v1/stock-opname/{{doc_no}}
Content-Type: application/json
Accept-Language: en
Authorization: Bearer {{login.response.body.data.token.access}}
 
###

@doc_no_cancel = SE2411300008
# @name get_stock_opname_reports
PATCH {{host-inventory}}/v1/stock-opname/{{doc_no}}/cancel
Content-Type: application/json
Accept-Language: en
Authorization: Bearer {{login.response.body.data.token.access}}
 
###

