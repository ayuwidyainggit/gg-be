### Get Master Price ### | query params filter: q=68593150
# ?q=&page=1&limit=10&sort=price_id:desc
GET {{master_url}}/v1/prices
Accept: application/json
Accept-Language: id
Authorization: Bearer {{login.response.body.data.token.access}}

### End of Get Master Price

@createdAt = {{$datetime 'YYYY-MM-DD'}}

### Create Master Price  
POST {{master_url}}/v1/prices
Content-Type: application/json
Accept-Language: en
Authorization: Bearer {{login.response.body.data.token.access}}

{
	"coverage": "N",
	"effective_date": "2025-01-17",
	"pro_id": 477,
	"unit_id1": "PCS",
	"unit_id2": "PCK",
	"unit_id3": "CTN",
	"conv_unit2": 2,
	"conv_unit3": 3,
	"purch_price1": 100.0,
	"purch_price2": 200.0,
	"purch_price3": 300.0,
	"sell_price1": 150.0,
	"sell_price2": 250.0,
	"sell_price3": 350.0,
	"new_purch_price1": 110.0,
	"new_purch_price2": 210.0,
	"new_purch_price3": 310.0,
	"new_sell_price1": 160.0,
	"new_sell_price2": 260.0,
	"new_sell_price3": 360.0,
    "distributor_ids": [40,41],
    "expiration_ms": 600000
}
### End of Create Master Price

### Get M Price Queue  
### /%2F/manage-price.events.create.delay/get
POST http://127.0.0.1:15672/api/queues/%2F/manage-price.events.create.delay/get HTTP/1.1
# POST http://103.28.219.73:15672/api/queues/%2F/manage-price.events.create.delay/get HTTP/1.1
Authorization: Basic guest:guest
# Authorization: Basic admin:aremania
Content-Type: application/json

{
    "count": 15,
    "ackmode": "ack_requeue_true",
    "encoding": "auto"
}
### End of Get M Price Queue 



